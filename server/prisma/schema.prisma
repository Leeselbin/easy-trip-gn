generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model BusStop {
  id        String       @id
  name      String
  latitude  Float
  longitude Float
  arrivals  BusArrival[]
}

model BusArrival {
  id             Int     @id @default(autoincrement())
  routeName      String
  arrivalMinutes Int
  isLowFloor     Boolean
  busStop        BusStop @relation(fields: [busStopId], references: [id])
  busStopId      String
}
